# OPTIONAL — turns on grounded AI gap synthesis. All free. Pick ONE.
# Copy to ".env" in the project root; the FastAPI server loads it on startup.

# Google AI Studio (recommended free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# or Groq (free): https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY

# or run locally with no key: install https://ollama.com then: ollama run llama3.2
# (no variable needed — auto-detected on localhost:11434)

# Force a provider: gemini | groq | ollama | none
#RESEARCH_LLM_PROVIDER= 
